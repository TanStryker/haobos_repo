<view class="card">
  <view class="row" style="justify-content: space-between;">
    <view class="hint">当前账号：{{userId}}</view>
    <button size="mini" bindtap="onLogout">退出</button>
  </view>
  <view class="field">
    <view class="label">当前规则</view>
    <view class="hint" wx:if="{{!ruleLoaded}}">加载中...</view>
    <view wx:if="{{ruleLoaded}}">
      <view class="hint">人员类型：{{workType === 'offsite' ? '外派' : '驻场'}}</view>
      <view class="hint">规则数量：{{rules.length}}</view>
      <view class="hint" wx:if="{{rules.length === 0}}">未配置可用打卡规则</view>
      <view wx:if="{{rules.length > 0}}">
        <view class="hint">优先规则：{{rules[0].name}}</view>
        <view class="hint">时间：{{rules[0].start_time}} - {{rules[0].end_time}}</view>
        <view class="hint" wx:if="{{rules[0].address_hint}}">地点提示：{{rules[0].address_hint}}</view>
        <view class="hint" wx:if="{{rules[0].allowed_radius_m}}">半径：{{rules[0].allowed_radius_m}}m</view>
      </view>
    </view>
  </view>
  <button class="btn" type="primary" bindtap="onChooseAndPunch" loading="{{loading}}">获取当前定位并打卡</button>
  <button class="btn" bindtap="toHistory">查看最近5次</button>
  <view class="hint {{msgType}}">{{msg}}</view>
</view>
